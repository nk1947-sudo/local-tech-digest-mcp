# ─── SMTP ────────────────────────────────────────────────────────────────────
# For Gmail: enable 2-Step Verification → generate 16-char App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Who receives the digest
NOTIFY_EMAIL=you@gmail.com

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Full IANA timezone name
TZ=America/New_York

# ─── Job digest tuning ───────────────────────────────────────────────────────
# Minimum stack-match score (0–14) for a job to appear in the email
# 0 = all accepted jobs  |  2 = at least one stack hit  |  6 = strong matches only
MIN_JOB_SCORE=0

# Max jobs shown per domain per email (prevents bloated first-run emails)
# 4 domains × 25 = up to 100 USA + 100 international cards per digest
MAX_JOBS_PER_DOMAIN=25
